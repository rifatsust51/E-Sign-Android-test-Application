<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F7">

    <!-- ── Blue header (Responsive) ───────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1565C0"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- Back row -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ Back"
            android:textColor="#BBDEFB"
            android:textSize="15sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirmation"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Transaction Details"
            android:textColor="#BBDEFB"
            android:textSize="13sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- ── Scrollable content (Responsive height) ─────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <!-- ── Transaction details card (Responsive width) ──────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <!-- From → To avatars (Responsive sizing) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="16dp">

                        <!-- FROM -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp">
                                <View
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/bg_avatar_circle"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="From"
                                android:textSize="10sp"
                                android:textColor="#1565C0"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:id="@+id/tvFromName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="10sp"
                                android:textColor="#1565C0"
                                android:gravity="center"
                                android:maxLines="2"
                                android:maxWidth="100dp"/>
                        </LinearLayout>

                        <!-- Arrow (Responsive) -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="►"
                            android:gravity="center"
                            android:textColor="#1565C0"
                            android:textSize="14sp"/>

                        <!-- TO -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp">
                                <View
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:background="@drawable/bg_avatar_circle"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="To"
                                android:textSize="10sp"
                                android:textColor="#1565C0"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:id="@+id/tvToAccount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textSize="10sp"
                                android:textColor="#1565C0"
                                android:gravity="center"
                                android:maxLines="2"
                                android:maxWidth="100dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Amount (Scalable text) -->
                    <TextView
                        android:id="@+id/tvAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BDT 0.00"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#1C1917"
                        android:gravity="center"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvChannelLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NPSB Transfer"
                        android:textSize="13sp"
                        android:textColor="#1565C0"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="12dp"/>

                    <!-- Account Name row (Responsive layout) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Account Name"
                            android:textColor="#78716C"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvDetailAccountName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="#1C1917"
                            android:textSize="13sp"
                            android:gravity="end"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="10dp"/>

                    <!-- Source Account row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Source Account"
                            android:textColor="#78716C"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvDetailSourceAcct"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="#1C1917"
                            android:textSize="13sp"
                            android:gravity="end"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="10dp"/>

                    <!-- Beneficiary Account row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Beneficiary Account"
                            android:textColor="#78716C"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/tvDetailBeneficiary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="#1C1917"
                            android:textSize="13sp"
                            android:gravity="end"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── TicThik notification message card (hidden initially) ──────── -->
            <LinearLayout
                android:id="@+id/notificationContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <!-- ── Signing status text ──────────────────────────────────────── -->
            <TextView
                android:id="@+id/tvSigningStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏳ Waiting for TicThik push notification..."
                android:textSize="12sp"
                android:textColor="#F59E0B"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- ── Fixed bottom buttons (Always visible, responsive sizing) ─────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:text="Tap to Confirm"
            android:textStyle="bold"
            android:textSize="15sp"
            android:enabled="false"
            app:cornerRadius="12dp"
            app:backgroundTint="#10B981"
            android:layout_marginBottom="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeny"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:text="Tap to Deny"
            android:textStyle="bold"
            android:textSize="15sp"
            android:enabled="true"
            app:cornerRadius="12dp"
            app:backgroundTint="#EF4444"/>

    </LinearLayout>

</LinearLayout>