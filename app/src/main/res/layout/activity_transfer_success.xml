<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F4">

    <!-- Blue header - Responsive height based on screen size -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="150dp"
        android:orientation="vertical"
        android:background="#1565C0"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:gravity="bottom">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹ Back"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Success"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transaction Successful."
            android:textColor="#BBDEFB"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- White card - Responsive with proper margins for all screen sizes -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Green circle check -->
                <TextView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:text="✓"
                    android:textSize="34sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_success_circle"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvSuccessAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BDT 0.00"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#1C1917"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvSuccessChannel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NPSB Transfer"
                    android:textSize="13sp"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="20dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0"
                    android:layout_marginBottom="14dp"/>

                <!-- Transaction Date Time Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Transaction Date Time"
                        android:textColor="#78716C"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvSuccessDateTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#1C1917"
                        android:textSize="13sp"
                        android:gravity="end"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0"
                    android:layout_marginBottom="10dp"/>

                <!-- Account Name Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Account Name"
                        android:textColor="#78716C"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvSuccessName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#1C1917"
                        android:textSize="13sp"
                        android:gravity="end"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0"
                    android:layout_marginBottom="10dp"/>

                <!-- Source Account Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Source Account"
                        android:textColor="#78716C"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/tvSuccessAccount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="#1C1917"
                        android:textSize="13sp"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Share Receipt Button -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnShareReceipt"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        app:cornerRadius="30dp"
                        app:backgroundTint="#1565C0"
                        android:text="↓"
                        android:textSize="22sp"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share Receipt"
                        android:textSize="13sp"
                        android:textColor="#1565C0"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</LinearLayout>