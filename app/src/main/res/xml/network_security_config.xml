<?xml version="1.0" encoding="utf-8"?>
<network-security-config>

    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="@raw/server_ca"/>
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">
            portal.test.reliefvalidation.com.bd
        </domain>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="@raw/server_ca"/>
        </trust-anchors>
    </domain-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="false">192.168.0.155</domain>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="@raw/server_ca"/>
        </trust-anchors>
    </domain-config>

    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="@raw/server_ca"/>
        </trust-anchors>
    </debug-overrides>

</network-security-config>